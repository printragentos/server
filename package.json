{
  "name": "printr-agent-os",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,cyan \"node --watch server.js\" \"npm run dev --prefix frontend\"",
