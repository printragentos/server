    "@solana/web3.js": "^1.95.5",
    "bs58": "^5.0.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "pino-pretty": "^11.3.0",
    "uuid": "^10.0.0",
    "viem": "^2.21.19"
  }
}
